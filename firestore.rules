
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }

    function isLibrarian() {
      return isSignedIn() && (getUserData().role == 'Librarian' || getUserData().role == 'Admin');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isLibrarian();
      allow list: if isAdmin() || isLibrarian();
      
      // Allow creation if the user is signing up with an NEU email.
      // Admins can create/update any user.
      allow create: if (isSignedIn() && request.resource.data.institutionalEmail.matches('.*@neu.edu.ph')) || isAdmin();
      allow update: if (isOwner(userId) && request.resource.data.institutionalEmail.matches('.*@neu.edu.ph')) || isAdmin();
      allow delete: if isAdmin();
    }

    match /visits/{visitId} {
      // Admins and librarians can read all logs.
      allow get, list: if isAdmin() || isLibrarian();
      // Allow creation if the visitor states a valid NEU email.
      allow create: if request.resource.data.visitorEmail.matches('.*@neu.edu.ph');
      allow update, delete: if false; 
    }
  }
}
