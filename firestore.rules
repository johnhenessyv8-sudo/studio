
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Any signed-in user can read and update their own profile.
      // Any signed-in user can read the list (for now, based on your request).
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false; 
    }

    match /visits/{visitId} {
      // Any authenticated user can read the logs.
      allow read: if isSignedIn();
      
      // Public creation still allowed for visitors logging via email.
      allow create: if request.resource.data.visitorEmail.matches('.*@neu.edu.ph');
      
      allow update, delete: if false; 
    }
  }
}
