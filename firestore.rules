
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function isLibrarian() {
      return isSignedIn() && (getUserData().role == 'Librarian' || getUserData().role == 'Admin');
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Any signed-in user can read profiles.
      allow read: if isSignedIn();
      
      // Users can manage their own profile.
      // Admins and Librarians can manage all profiles.
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isLibrarian());
      
      // Only Admins can permanently delete user records.
      allow delete: if isAdmin(); 
    }

    match /visits/{visitId} {
      // Authenticated users (Admin/Librarian) can view the logs.
      allow read: if isSignedIn();
      
      // Public creation allowed for visitors logging via institutional email.
      allow create: if request.resource.data.visitorEmail.matches('.*@neu.edu.ph');
      
      allow update, delete: if isAdmin(); 
    }
  }
}
